# Python virtual environment
.venv/
venv/

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Build / dist
build/
dist/
*.egg-info/
# PyInstaller build logs dropped in the repo root (build_<version>.log)
build_*.log
# Inno Setup installer output (compiled Setup.exe)
installer/

# OS / editor junk
Thumbs.db
.DS_Store
.vscode/
.idea/

# App runtime output (deleted photos are moved here)
_deleted/

# App data + persisted state stores (machine-specific paths, user data):
# manoni_state / manoni_filters / manoni_actions / manoni-language / manoni-filters
manoni*.json
manoni-*.json

# Throwaway UI design / preview scratch files (standalone, not part of the app)
previews/
*_preview.py

# Personal planning / spec docs (kept local, not tracked)
spec/
TESTING_TODO.md

# Local scratch: files not needed to run the app (old prototypes, generated
# artifacts). Moved here out of the repo root; regenerate/delete freely.
temp/
# Generated by tests/make_test_chart.py — an artifact, not a source file.
test_chart.png

# Local asset generator for the Logo shapes — regenerates logos/*.png +
# labels/*.svg. Kept on disk for re-runs, but not tracked (an artifact source).
tools/make_labels.py
